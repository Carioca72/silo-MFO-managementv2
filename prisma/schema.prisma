// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  cnpj      String?
  phone     String?
  aum       Float    @default(0)
  riskProfile String @default("Moderado")
  studies   Study[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Study {
  id         String   @id @default(cuid())
  name       String
  client     Client   @relation(fields: [clientId], references: [id])
  clientId   String
  type       String   // "Estudo de Carteira" | "Relatório de Resultados"
  status     String   // "Concluído" | "Em Andamento" | "Erro"
  inputFile  String?
  result     Json?
  reports    Report[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  study       Study    @relation(fields: [studyId], references: [id])
  studyId     String
  format      String   // "PDF" | "XLSX"
  storagePath String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortfolioStudy {
  id             String   @id @default(cuid())
  tickers        String[]
  weights        Json
  benchmark      String
  targetReturn   Float?
  expectedReturn Float
  volatility     Float
  sharpeRatio    Float
  backtestReturn Float
  maxDrawdown    Float
  createdAt      DateTime @default(now())
  snapshots      AssetSnapshot[]
}

model AssetSnapshot {
  id        String         @id @default(cuid())
  study     PortfolioStudy @relation(fields: [studyId], references: [id])
  studyId   String
  ticker    String
  price     Float
  currency  String         @default("BRL")
  fxRate    Float          @default(1.0)
  createdAt DateTime       @default(now())
}
