# Arquivo de exemplo para variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores

# --- Microserviço Python ---

# Chave de API para a Groq (obrigatória para extração de dados de PDF)
GROQ_API_KEY="sua_chave_aqui"

# Chave de API para a Brapi (para dados do mercado brasileiro)
BRAPI_API_KEY="sua_chave_aqui"

# Chave de API para a Brasa (será usada futuramente para enriquecimento de dados)
# BRASA_API_KEY="sua_chave_aqui"
