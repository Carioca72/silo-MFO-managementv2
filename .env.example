# SILO MFO — .env COMPLETO
NODE_ENV=development
PORT=3000
DATABASE_URL=file:./silo.db

# GEMINI (injetado pelo AI Studio)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL=gemini-2.5-flash-latest

# COMDINHEIRO — credenciais NUNCA vão ao frontend
COMDINHEIRO_API_URL=https://api.comdinheiro.com.br/v1/ep1/import-data
COMDINHEIRO_USERNAME=mforlani
COMDINHEIRO_PASSWORD=<senha_real>
COMDINHEIRO_CACHE_TTL_SECONDS=300

# EMAIL
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=reports@silo.com.br
EMAIL_SMTP_PASS=<app_password_gmail>
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# WHATSAPP
WPP_SESSION_FOLDER=./wpp_sessions
WPP_TOKEN_SECRET=<token_seguro>

# DATACRAZY (passar documentação para implementar)
DATACRAZY_API_URL=https://api.datacrazy.io
DATACRAZY_API_KEY=<sua_chave>

# STORAGE
REPORT_STORAGE_PATH=./reports_storage

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime.
APP_URL="https://example.com"
