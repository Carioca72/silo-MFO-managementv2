datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  studies   Study[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Study {
  id          String   @id @default(cuid())
  name        String
  client      Client   @relation(fields: [clientId], references: [id])
  clientId    String
  type        String   // Ex: "Estudo de Carteira", "Relatório de Resultados"
  status      String   // Ex: "Concluído", "Em Andamento", "Erro"
  inputFile   String?  // Path para o arquivo de input (ex: CEI)
  result      Json?    // Resultados da análise (Markowitz, etc)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Report      Report[]
}

model Report {
  id        String   @id @default(cuid())
  study     Study    @relation(fields: [studyId], references: [id])
  studyId   String
  format    String   // Ex: "PDF", "DOCX"
  storagePath String // Path para o arquivo gerado
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}